@page
@model EjemploP2.Pages.Vistas.GestionDeDronesModel
@{
    ViewData["Title"] = "Gestión de Drones";
}

<div class="border-b border-gray-200 pb-4 mb-8 flex justify-between items-end">
    <div>
        <h2 class="text-3xl font-extrabold text-gray-900 tracking-tight">🚁 Gestión de Drones</h2>
        <p class="mt-2 text-sm text-gray-600 font-medium">Registre nuevos drones o visualice la flota actual del sistema.</p>
    </div>
    <a asp-page="/Index" class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-2 px-4 border border-gray-300 rounded-lg shadow-sm transition-all text-sm flex items-center gap-2">
        ⬅️ Volver al Panel
    </a>
</div>

@if (TempData["MensajeExito"] != null)
{
    <div class="mb-6 bg-green-50 border-l-4 border-green-500 p-4 rounded-r-lg shadow-sm flex items-center justify-between">
        <div class="flex items-center">
            <span class="text-green-500 text-xl mr-3">✅</span>
            <p class="text-green-800 font-medium">@TempData["MensajeExito"]</p>
        </div>
    </div>
}

@if (TempData["MensajeError"] != null)
{
    <div class="mb-6 bg-red-50 border-l-4 border-red-500 p-4 rounded-r-lg shadow-sm flex items-center justify-between">
        <div class="flex items-center">
            <span class="text-red-500 text-xl mr-3">⚠️</span>
            <p class="text-red-800 font-medium">@TempData["MensajeError"]</p>
        </div>
    </div>
}

<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
    
    <div class="lg:col-span-5 flex flex-col gap-6">
        
        <form method="post" class="bg-white p-6 rounded-2xl border border-gray-200 shadow-md flex flex-col gap-4">
            <h3 class="font-bold text-indigo-900 text-xl border-b border-gray-100 pb-3">Registrar Nuevo Dron</h3>
            
            <div>
                <label for="nombreDron" class="block text-sm font-semibold text-gray-700 mb-2">Nombre del Dron</label>
                <input type="text" id="nombreDron" asp-for="NuevoNombreDron" required placeholder="Ej. Dron_Alfa_01"
                       class="block w-full px-4 py-3 text-gray-700 bg-gray-50 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors shadow-sm" />
            </div>

            <button type="submit" asp-page-handler="CrearDron" class="w-full mt-4 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-4 rounded-lg shadow-md transition-all flex justify-center items-center gap-2">
                ➕ Agregar Dron al Sistema
            </button>
        </form>
        
    </div>

    <div class="lg:col-span-7 flex flex-col h-full">
        
        <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-md h-full flex flex-col">
            <h3 class="font-bold text-gray-800 text-xl border-b border-gray-100 pb-3 mb-4 flex justify-between items-center">
                Flota de Drones
                <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded-full">
                    @(Model.ListaDeDrones != null ? Model.ListaDeDrones.Length : 0) registrados
                </span>
            </h3>
            
            <div class="flex-grow overflow-y-auto max-h-[400px] pr-2">
                
                @if (Model.ListaDeDrones != null && Model.ListaDeDrones.Length > 0)
                {
                    <ul class="space-y-3">
                        @foreach (var dron in Model.ListaDeDrones)
                        {
                            <li class="bg-gray-50 border border-gray-200 rounded-lg p-4 flex items-center gap-4 hover:bg-indigo-50 hover:border-indigo-200 transition-colors">
                                <div class="bg-indigo-100 p-2 rounded-full">
                                    🚁
                                </div>
                                <span class="text-gray-700 font-semibold text-lg">@dron</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="flex flex-col items-center justify-center h-full text-center text-gray-500 py-10">
                        <span class="text-4xl mb-3">📭</span>
                        <p class="text-lg font-medium">No hay drones registrados.</p>
                        <p class="text-sm">Agregue uno usando el formulario o cargue un archivo XML.</p>
                    </div>
                }
                
            </div>
        </div>
        
    </div>
</div>