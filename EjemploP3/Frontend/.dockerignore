# 1. Dependencias (¡El más importante!)
node_modules/

# 2. Archivos de entorno y secretos
.env
.env.*
*.local

# 3. Carpetas de compilación locales 
# (Docker generará su propio dist/ fresco desde cero)
dist/
dist-ssr/
build/

# 4. Logs de errores de NPM/Yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 5. Archivos de Git y del propio Docker
.git/
.gitignore
Dockerfile
.dockerignore
docker-compose*.yml

# 6. Archivos de configuración de tu editor (VS Code, etc.)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?