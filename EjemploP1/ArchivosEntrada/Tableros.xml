<?xml version="1.0" encoding="UTF-8"?>
<tableros>

  <!-- Tablero 1: “Corazon” (m=20). Rejilla inicial tipo “contorno” para que con tus reglas se vaya rellenando. -->
  <tablero>
    <nombre>Corazon</nombre>
    <periodos>3</periodos>
    <m>20</m>
    <rejilla>
      <!-- Lóbulo izquierdo -->
      <celda f="4" c="6"/>
      <celda f="4" c="7"/>
      <celda f="4" c="8"/>
      <celda f="5" c="5"/>
      <celda f="5" c="9"/>
      <celda f="6" c="5"/>
      <celda f="6" c="9"/>
      <celda f="7" c="6"/>
      <celda f="7" c="8"/>

      <!-- Lóbulo derecho -->
      <celda f="4" c="13"/>
      <celda f="4" c="14"/>
      <celda f="4" c="15"/>
      <celda f="5" c="12"/>
      <celda f="5" c="16"/>
      <celda f="6" c="12"/>
      <celda f="6" c="16"/>
      <celda f="7" c="13"/>
      <celda f="7" c="15"/>

      <!-- Costados hacia abajo -->
      <celda f="8" c="7"/>
      <celda f="8" c="14"/>
      <celda f="9" c="8"/>
      <celda f="9" c="13"/>
      <celda f="10" c="9"/>
      <celda f="10" c="12"/>
      <celda f="11" c="10"/>
      <celda f="11" c="11"/>

      <!-- Punta del corazón -->
      <celda f="12" c="10"/>
      <celda f="12" c="11"/>
      <celda f="13" c="10"/>
      <celda f="13" c="11"/>
    </rejilla>
  </tablero>

  <!-- Tablero 2: “Letra_A” (m=15). Semilla con “hueso” de A para que se engrose con periodos. -->
  <tablero>
    <nombre>Letra_A</nombre>
    <periodos>4</periodos>
    <m>15</m>
    <rejilla>
      <!-- Pico superior -->
      <celda f="3" c="8"/>

      <!-- Diagonal izquierda -->
      <celda f="4" c="7"/>
      <celda f="5" c="6"/>
      <celda f="6" c="5"/>
      <celda f="7" c="5"/>
      <celda f="8" c="5"/>
      <celda f="9" c="5"/>
      <celda f="10" c="5"/>

      <!-- Diagonal derecha -->
      <celda f="4" c="9"/>
      <celda f="5" c="10"/>
      <celda f="6" c="11"/>
      <celda f="7" c="11"/>
      <celda f="8" c="11"/>
      <celda f="9" c="11"/>
      <celda f="10" c="11"/>

      <!-- Barra central -->
      <celda f="7" c="6"/>
      <celda f="7" c="7"/>
      <celda f="7" c="8"/>
      <celda f="7" c="9"/>
      <celda f="7" c="10"/>
    </rejilla>
  </tablero>

  <!-- Tablero 3: “Estrella” (m=21). Semilla tipo estrella para que se expanda/defina con más periodos. -->
  <tablero>
    <nombre>Estrella</nombre>
    <periodos>5</periodos>
    <m>21</m>
    <rejilla>
      <!-- Centro -->
      <celda f="11" c="11"/>

      <!-- Brazos (cruz) -->
      <celda f="9" c="11"/>
      <celda f="10" c="11"/>
      <celda f="12" c="11"/>
      <celda f="13" c="11"/>

      <celda f="11" c="9"/>
      <celda f="11" c="10"/>
      <celda f="11" c="12"/>
      <celda f="11" c="13"/>

      <!-- Diagonales -->
      <celda f="10" c="10"/>
      <celda f="9" c="9"/>
      <celda f="12" c="12"/>
      <celda f="13" c="13"/>

      <celda f="10" c="12"/>
      <celda f="9" c="13"/>
      <celda f="12" c="10"/>
      <celda f="13" c="9"/>

      <!-- Puntas extra -->
      <celda f="7" c="11"/>
      <celda f="15" c="11"/>
      <celda f="11" c="7"/>
      <celda f="11" c="15"/>
    </rejilla>
  </tablero>

</tableros>
