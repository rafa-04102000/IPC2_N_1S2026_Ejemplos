digraph ListaCircular {
    // Configuración general del lienzo
    // rankdir=LR hace que el grafo se dibuje de Izquierda a Derecha (Left to Right)
    rankdir=TB;
    bgcolor="#F9F9F9"; // Un fondo gris muy claro para resaltar los nodos

    // Plantilla global para los nodos
    node [
        shape=record, 
        style=filled, 
        fillcolor="#E8F4F8", // Un tono azul pastel
        color="#2980B9",     // Borde azul oscuro
        fontname="Helvetica", 
        fontsize=12,
        penwidth=1.5
    ];

    // Plantilla global para las flechas (aristas)
    edge [
        color="#2C3E50", 
        arrowhead=vee, 
        penwidth=1.2
    ];

    // 1. DECLARACIÓN DE LOS NODOS
    // Usamos la sintaxis { <nombre_puerto> etiqueta | <nombre_puerto> etiqueta }
    // Esto divide el nodo visualmente en dos partes: el dato y el puntero al siguiente
    Nodo1 [label="{ <dato> 15 | { <sig> siguiente | <ant> anterior } }"];
    Nodo2 [label="{ <dato> 42 | { <sig> siguiente | <ant> anterior } }"];
    Nodo3 [label="{ <dato> 89 | { <sig> siguiente | <ant> anterior } }"];
    Nodo4 [label="{ <dato> 10 | { <sig> siguiente | <ant> anterior } }"];

    // Nodo especial para indicar dónde empieza la lista (Opcional pero muy didáctico)
    Cabeza [shape=plaintext, style="", fillcolor="", fontcolor="#E74C3C", fontsize=14, label="Cabeza"];

    // 2. CONEXIONES (ARISTAS)
    // Conectamos el indicador "Cabeza" al primer nodo
    Cabeza -> Nodo1:dato [color="#E74C3C", style=dotted];

    // Conectamos los nodos usando los "puertos" que definimos arriba
    // Le decimos a Graphviz: "sal del puerto <sig> y entra al puerto <dato>"
    Nodo1:sig -> Nodo2:dato;
    Nodo2:sig -> Nodo3:dato;
    Nodo3:sig -> Nodo4:dato;
    
    Nodo4:ant -> Nodo3:ant;
    Nodo3:ant -> Nodo2:ant;
    Nodo2:ant -> Nodo1:ant;
    

    // 3. EL ENLACE CIRCULAR
    // Conectamos el último nodo de regreso al primero.
    // Usamos colores y estilos diferentes para que los estudiantes noten que es el cierre del ciclo.
    Nodo1:ant -> Nodo4:dato [
        color="#27AE60",       // Color verde para destacar
        style=dashed,          // Línea punteada
        label=" Repite el Ciclo", 
        fontcolor="#27AE60",
        fontsize=10,
        rankdir=TB
    ];
    
    Nodo4:sig -> Nodo1:dato [
        color="#27AE60",       // Color verde para destacar
        style=dashed,          // Línea punteada
        label=" Repite el Ciclo", 
        fontcolor="#27AE60",
        fontsize=10
    ];
    
    Cola [shape=plaintext, style="", fillcolor="", fontcolor="#E74C3C", fontsize=14, label="Cola"];
    Cola -> Nodo4:dato [color="#E74C3C", style=dotted];
}